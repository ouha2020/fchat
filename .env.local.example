NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase 新版 API key（推荐，名字以 sb_publishable_ 开头）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
# 或者旧版 anon key（任选其一即可）
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only key for Next.js API routes. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# PWA Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# Family code email delivery (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM="Family Chat <noreply@example.com>"
